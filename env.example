# Copie para .env na máquina local (opcional) ou defina no painel do host (Netlify / Vercel / CI).

# Manutenção da página de transição (runtime-config.js gerado por `npm run build`)
# true | 1 | yes | on → mostra ecrã amigável em vez da mensagem de migração
MAINTENANCE=false

# Alias aceite pelo mesmo script de build
# RETAINLY_MAINTENANCE=false
